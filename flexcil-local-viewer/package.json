{
  "name": "flexcil-local-viewer",
  "private": true,
  "version": "1.0.0",
  "description": "Local Flexcil backup PDF viewer browser launcher",
  "author": "Jan",
  "main": "launcher/server.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:exe": "npm run build && pkg launcher/server.cjs --targets node18-win-x64 --output release/Flexcil-Local-Viewer-Browser-Launcher.exe",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.576.0",
    "pako": "^2.1.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "pkg": "^5.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^5.4.11"
  },
  "pkg": {
    "assets": [
      "dist/**/*"
    ]
  }
}
